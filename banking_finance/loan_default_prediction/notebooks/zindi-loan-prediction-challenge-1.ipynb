test_df['is_referred'] = test_df['referredby'].notna().astype(int)

for col in cat_cols:
    test_df[col] = test_df[col].fillna('Unknown')

test_df['longitude_gps'] = test_df['longitude_gps'].fillna(test_df['longitude_gps'].median()).fillna(0)
test_df['latitude_gps'] = test_df['latitude_gps'].fillna(test_df['latitude_gps'].median()).fillna(0)

test_df['is_top_bank'] = test_df['bank_name_clients'].isin(top_banks).astype(int)
test_df['is_employed'] = test_df['employment_status_clients'].apply(
    lambda x: 1 if x in ['Employed', 'Self-Employed', 'Business Owner'] else 0
)

test_df.drop(columns=['approveddate_str', 'creationdate_str', 'birthdate_str'], inplace=True)

# Keep only the columns that were used in training (in the same order)
X_test = test_df.drop(columns=[col for col in drop_existing if col in test_df.columns], errors='ignore')
X_test = X_test.reindex(columns=X_train.columns, fill_value=0)

print("Test features shape:", X_test.shape)
assert X_test.isnull().sum().sum() == 0, "There are still missing values in the test data!"

# Apply the same preprocessor to test data
X_test_processed = preprocessor.transform(X_test)

# 12. Make predictions on the test set
predictions = best_rf.predict(X_test_processed)

