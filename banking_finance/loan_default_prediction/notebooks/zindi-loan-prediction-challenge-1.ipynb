test_df['approveddate'] = test_df['approveddate'].fillna(pd.Timestamp('2020-01-01'))
test_df['creationdate'] = test_df['creationdate'].fillna(pd.Timestamp('2020-01-01'))
test_df['birthdate'] = test_df['birthdate'].fillna(pd.Timestamp('1970-01-01'))

test_df['age_at_approval'] = (test_df['approveddate'] - test_df['birthdate']).dt.days // 365
