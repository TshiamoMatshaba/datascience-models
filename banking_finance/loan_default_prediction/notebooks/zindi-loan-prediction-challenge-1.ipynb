#Files path
path = "/kaggle/input/datasets/tshiamomatshaba/zindi-loan-prediction-challenge/"


# 3. Load the three training CSV files
train_perf = pd.read_csv(path + 'trainperf.csv')          # Performance data (has the target: good/bad)
train_demo = pd.read_csv(path + 'traindemographics.csv')  # Demographic data (age, bank, etc.)
train_prev = pd.read_csv(path + 'trainprevloans.csv')     # Previous loans history

print("Training files loaded. Shapes:", train_perf.shape, train_demo.shape, train_prev.shape)

# 4. Aggregate previous loans to create one row per customer
# Each customer may have multiple past loans. We create summary features.
prev_agg_train = train_prev.groupby('customerid').agg(
    prev_loan_count=('loannumber', 'count'),          # How many past loans
    prev_avg_amount=('loanamount', 'mean'),           # Average loan amount of past loans
    prev_avg_termdays=('termdays', 'mean')            # Average loan term of past loans
).reset_index()

# 5. Merge all training data into one big table
train_df = train_perf.merge(train_demo, on='customerid', how='left')
train_df = train_df.merge(prev_agg_train, on='customerid', how='left')

# For customers with no previous loans, fill the new columns with 0
train_df['prev_loan_count'] = train_df['prev_loan_count'].fillna(0)
train_df['prev_avg_amount'] = train_df['prev_avg_amount'].fillna(0)
train_df['prev_avg_termdays'] = train_df['prev_avg_termdays'].fillna(0)

# 6. Feature engineering: create new columns that help predict default
# First, clean the date columns by taking only the first 10 characters (YYYY-MM-DD)
train_df['approveddate_str'] = train_df['approveddate'].astype(str).str[:10]
train_df['creationdate_str'] = train_df['creationdate'].astype(str).str[:10]
train_df['birthdate_str'] = train_df['birthdate'].astype(str).str[:10]

# Convert those strings to actual dates (if format is wrong, turn into NaT)
train_df['approveddate'] = pd.to_datetime(train_df['approveddate_str'], errors='coerce')
train_df['creationdate'] = pd.to_datetime(train_df['creationdate_str'], errors='coerce')
train_df['birthdate'] = pd.to_datetime(train_df['birthdate_str'], errors='coerce')

# Create a feature that tells us if birthdate was missing (1) or not (0)
train_df['birthdate_missing'] = train_df['birthdate'].isna().astype(int)

# Fill missing dates with default values so we don't have empty cells
train_df['approveddate'] = train_df['approveddate'].fillna(pd.Timestamp('2020-01-01'))
train_df['creationdate'] = train_df['creationdate'].fillna(pd.Timestamp('2020-01-01'))
train_df['birthdate'] = train_df['birthdate'].fillna(pd.Timestamp('1970-01-01'))

# Calculate age at the time of loan approval (in years)
train_df['age_at_approval'] = (train_df['approveddate'] - train_df['birthdate']).dt.days // 365
train_df['age_at_approval'] = train_df['age_at_approval'].clip(upper=100)  # Cap at 100 years

# Extract day of week and month from approval date
train_df['approval_dayofweek'] = train_df['approveddate'].dt.dayofweek
train_df['approval_month'] = train_df['approveddate'].dt.month

# How many days between loan creation and approval?
train_df['days_creation_to_approval'] = (train_df['approveddate'] - train_df['creationdate']).dt.days

# Repayment ratio: total due divided by loan amount (higher = more expensive loan)
train_df['repayment_ratio'] = train_df['totaldue'] / train_df['loanamount']
train_df['repayment_ratio'] = train_df['repayment_ratio'].clip(upper=5)  # Remove extreme outliers

# Referral feature: was the customer referred by someone?
train_df['is_referred'] = train_df['referredby'].notna().astype(int)

# For categorical columns, fill missing values with 'Unknown'
cat_cols = ['bank_account_type', 'bank_name_clients', 'bank_branch_clients',
            'employment_status_clients', 'level_of_education_clients']
for col in cat_cols:
    train_df[col] = train_df[col].fillna('Unknown')

# GPS coordinates: fill missing with median, then with 0 if still missing
train_df['longitude_gps'] = train_df['longitude_gps'].fillna(train_df['longitude_gps'].median()).fillna(0)
train_df['latitude_gps'] = train_df['latitude_gps'].fillna(train_df['latitude_gps'].median()).fillna(0)

# Find the 10 most common bank names (from training data)
top_banks = train_df['bank_name_clients'].value_counts().head(10).index
train_df['is_top_bank'] = train_df['bank_name_clients'].isin(top_banks).astype(int)

# Create a feature: is the customer employed? (Employed, Self-Employed, Business Owner = 1, else 0)
train_df['is_employed'] = train_df['employment_status_clients'].apply(
    lambda x: 1 if x in ['Employed', 'Self-Employed', 'Business Owner'] else 0
)

# Drop the temporary string columns we created for dates
train_df.drop(columns=['approveddate_str', 'creationdate_str', 'birthdate_str'], inplace=True)

# 7. Prepare the target variable (what we want to predict)
# Convert 'Good' to 1 and 'Bad' to 0
train_df['good_bad_flag'] = train_df['good_bad_flag'].map({'Good': 1, 'Bad': 0})

# 8. Separate features (X) from target (y)
# We drop columns that are not useful for prediction (IDs, dates, raw text)
drop_cols = ['customerid', 'systemloanid', 'loannumber', 'approveddate', 'creationdate',
             'closeddate', 'firstduedate', 'firstrepaiddate', 'referredby', 'birthdate',
             'good_bad_flag']
drop_existing = [col for col in drop_cols if col in train_df.columns]

X_train = train_df.drop(columns=drop_existing)  # All input features
y_train = train_df['good_bad_flag']             # Target (1 = Good, 0 = Bad)

print("Training features shape:", X_train.shape)
print("Target distribution:\n", y_train.value_counts(normalize=True))

# 9. Preprocessing: scale numbers and convert text to numbers
# Separate columns by type
cat_features = X_train.select_dtypes(include=['object']).columns.tolist()   # Text columns
num_features = X_train.select_dtypes(include=['int64', 'float64']).columns.tolist()  # Number columns

# Create a preprocessor that:
# - Scales numeric features (so they have mean 0 and standard deviation 1)
# - One-hot encodes categorical features (creates new 0/1 columns for each category)
preprocessor = ColumnTransformer([
    ('num', StandardScaler(), num_features),
    ('cat', OneHotEncoder(handle_unknown='ignore', sparse_output=False), cat_features)
])

# Apply the preprocessor to the training data
X_train_processed = preprocessor.fit_transform(X_train)
print("Processed training shape:", X_train_processed.shape)

# 10. Train a Random Forest model with the best parameters found earlier
best_rf = RandomForestClassifier(
    n_estimators=100,          # Number of trees in the forest
    min_samples_split=5,       # Minimum samples required to split a node
    min_samples_leaf=1,        # Minimum samples in a leaf node
    max_depth=10,              # Maximum depth of each tree
    class_weight=None,         # No extra weight balancing (we rely on good features)
    random_state=42,           # Ensures we get the same results every time
    n_jobs=-1                  # Use all CPU cores for faster training
)
best_rf.fit(X_train_processed, y_train)
print("Model training completed.")

# Save the preprocessor and model so we can reuse them later
joblib.dump(preprocessor, 'preprocessor.pkl')
joblib.dump(best_rf, 'model.pkl')
print("Preprocessor and model saved.")

# 11. Now load and process the test data (exactly the same steps as training)
